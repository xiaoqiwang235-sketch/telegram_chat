# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_USER_IDS=123456789,987654321

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=telegram_chatbot
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# XiaoMi MiMo API Configuration
MIMO_API_BASE_URL=https://api.xiaomimimo.com
MIMO_API_KEY=your_mimo_api_key_here
MIMO_MODEL=mi-mimo-model

# OpenAI Embedding API Configuration
OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_EMBEDDING_DIMENSIONS=1536

# Faiss Configuration
FAISS_INDEX_TYPE=IndexFlatL2
FAISS_NLIST=100
FAISS_NPROBE=10

# Rate Limiting Configuration
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Memory Configuration
SHORT_TERM_MEMORY_MAX_MESSAGES=50
LONG_TERM_MEMORY_RETRIEVE_TOP_K=5
LONG_TERM_MEMORY_REBUILD_THRESHOLD=1000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
