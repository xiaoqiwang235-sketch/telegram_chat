# ============================================
# Telegram Bot Configuration
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_USER_IDS=123456789,987654321

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=telegram_chatbot
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ============================================
# Mimo API Configuration (LLM)
# ============================================
MIMO_API_BASE_URL=https://api.xiaomimimo.com
MIMO_API_KEY=your_mimo_api_key_here
MIMO_MODEL=mimo-v2.5

# ============================================
# Embedding Configuration (Choose ONE)
# ============================================
# Option 1: Local embedding model (Recommended, Free)
USE_LOCAL_EMBEDDINGS=true
LOCAL_EMBEDDING_MODEL=moka-ai/m3e-base
LOCAL_EMBEDDING_DEVICE=cpu
LOCAL_EMBEDDING_DIMENSIONS=768

# Option 2: OpenAI API (Paid)
# USE_LOCAL_EMBEDDINGS=false
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE_URL=https://api.openai.com
# OPENAI_EMBEDDING_DIMENSIONS=1536

# ============================================
# Network / Proxy Configuration
# ============================================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# HF_ENDPOINT=https://hf-mirror.com

# ============================================
# Telegram Timeout Configuration
# ============================================
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=30

# ============================================
# Faiss Configuration
# ============================================
FAISS_INDEX_TYPE=IndexFlatL2
FAISS_NLIST=100
FAISS_NPROBE=10

# ============================================
# Rate Limiting Configuration
# ============================================
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================
# Memory Configuration
# ============================================
SHORT_TERM_MEMORY_MAX_MESSAGES=50
LONG_TERM_MEMORY_RETRIEVE_TOP_K=5
LONG_TERM_MEMORY_REBUILD_THRESHOLD=1000

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
